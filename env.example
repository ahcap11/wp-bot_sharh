# ─────────────────────────────────────────────────────────────
# Application Configuration
# ─────────────────────────────────────────────────────────────
# WebSocket server port (real-time monitoring stream)
PORT=8080
NODE_ENV=development
# HTTP health/readiness server port (used by load balancers / probes)
HEALTH_PORT=3001

# ─────────────────────────────────────────────────────────────
# AI Configuration
# Set the provider and the matching API key below.
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# ─────────────────────────────────────────────────────────────
# Chat History Configuration
# ─────────────────────────────────────────────────────────────
MAX_HISTORY_LENGTH=50
RESPONSE_DELAY=1000

# ─────────────────────────────────────────────────────────────
# Logging Configuration (error | warn | info | debug)
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# AI Service Configuration
# ─────────────────────────────────────────────────────────────
AI_MAX_TOKENS=150
AI_TEMPERATURE=0.7

# ─────────────────────────────────────────────────────────────
# WebSocket Security
# If set, clients must connect with ?token=<value>. Leave empty to disable.
# ─────────────────────────────────────────────────────────────
WS_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────
# Google Sheets Integration
# ─────────────────────────────────────────────────────────────
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Leads
# Provide credentials either inline as JSON or as a path to a key file
# kept OUTSIDE the repository. Never commit the actual key.
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_CREDENTIALS_PATH=

# ─────────────────────────────────────────────────────────────
# Neon Read-Only Search (used by the sales role for listing lookup)
# Use a READ-ONLY database user. The app never writes to this DB.
# ─────────────────────────────────────────────────────────────
NEON_SEARCH_ENABLED=false
NEON_READONLY_DATABASE_URL=
NEON_SEARCH_TABLE_NAME=asset_sales
NEON_SEARCHABLE_COLUMNS=title,subtitle,sector,region,emirate,description,price,revenue,tags,ribbon,sale_type
NEON_SEARCH_LIMIT=5

# ─────────────────────────────────────────────────────────────
# State Persistence
# Survives restarts/redeploys (chat history, roles, lead progress).
# In Docker, mount the directory as a volume to keep state.
# ─────────────────────────────────────────────────────────────
PERSISTENCE_ENABLED=true
PERSISTENCE_PATH=./.state/state.json

# ─────────────────────────────────────────────────────────────
# Access Control (allowlist + rate limit)
# ALLOWED_NUMBERS: comma-separated phone numbers (digits only, with country code).
# ─────────────────────────────────────────────────────────────
ALLOWLIST_ENABLED=false
ALLOWED_NUMBERS=
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX_MESSAGES=20
RATE_LIMIT_WINDOW_MS=60000

# --- Messaging transport ---
# Backend: "baileys" (WhatsApp Web, default) or "cloud" (official WhatsApp Cloud API)
WHATSAPP_TRANSPORT=baileys
# Required only when WHATSAPP_TRANSPORT=cloud (Cloud API adapter is a scaffold; implement before use)
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_API_VERSION=v21.0

# --- Listing data exposure (Step 4) ---
# Columns the bot may reveal to a client. Defaults to NEON_SEARCHABLE_COLUMNS.
# List ONLY client-safe columns; internal fields are never selected.
NEON_PUBLIC_COLUMNS=

# --- Manager handoff (Step 3) ---
# Comma-separated WhatsApp ids that receive lead notifications on qualify/escalate.
# Direct number example: 9715XXXXXXXX@s.whatsapp.net  | group example: XXXXXXXXXX@g.us
# When empty, handoff is logged only (no message sent).
HANDOFF_WHATSAPP_JIDS=

# --- Roles & group filtering (Step 6) ---
# Allow clients to switch the bot role via chat text. Default false (recommended).
ROLE_SWITCH_ENABLED=false
# WhatsApp ids permitted to switch roles even when ROLE_SWITCH_ENABLED=false.
OPERATOR_JIDS=
# Ignore group / broadcast / channel messages (1:1 inbound only). Default true.
IGNORE_GROUPS=true

# --- Session persistence (Step 7) ---
# Baileys auth dir. On Railway, point this at a mounted volume so the session
# survives redeploys instead of re-linking (QR) every time.
WHATSAPP_AUTH_DIR=./auth_info_baileys

# --- Rate limiting (Step 7) ---
# Enabled by default to prevent spam / cost abuse on a public number.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_MESSAGES=20
RATE_LIMIT_WINDOW_MS=60000

# --- QR linking page (read the QR as an image instead of from logs) ---
# Visit  https://<your-app>.up.railway.app/qr?token=<QR_ACCESS_TOKEN>  to scan.
# Served on the public health port. Set a non-empty token to protect it.
QR_ACCESS_TOKEN=
