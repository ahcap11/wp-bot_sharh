# ─────────────────────────────────────────────────────────────
# Application Configuration
# ─────────────────────────────────────────────────────────────
# WebSocket server port (real-time monitoring stream)
PORT=8080
NODE_ENV=development
# HTTP health/readiness server port (used by load balancers / probes)
HEALTH_PORT=3001

# ─────────────────────────────────────────────────────────────
# AI Configuration
# Set the provider and the matching API key below.
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# ─────────────────────────────────────────────────────────────
# Chat History Configuration
# ─────────────────────────────────────────────────────────────
MAX_HISTORY_LENGTH=50
RESPONSE_DELAY=1000

# ─────────────────────────────────────────────────────────────
# Logging Configuration (error | warn | info | debug)
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# AI Service Configuration
# ─────────────────────────────────────────────────────────────
AI_MAX_TOKENS=150
AI_TEMPERATURE=0.7

# ─────────────────────────────────────────────────────────────
# WebSocket Security
# If set, clients must connect with ?token=<value>. Leave empty to disable.
# ─────────────────────────────────────────────────────────────
WS_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────
# Google Sheets Integration
# ─────────────────────────────────────────────────────────────
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Leads
# Provide credentials either inline as JSON or as a path to a key file
# kept OUTSIDE the repository. Never commit the actual key.
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_CREDENTIALS_PATH=

# ─────────────────────────────────────────────────────────────
# Neon Read-Only Search (used by the sales role for listing lookup)
# Use a READ-ONLY database user. The app never writes to this DB.
# ─────────────────────────────────────────────────────────────
NEON_SEARCH_ENABLED=false
NEON_READONLY_DATABASE_URL=
NEON_SEARCH_TABLE_NAME=asset_sales
NEON_SEARCHABLE_COLUMNS=title,subtitle,sector,region,emirate,description,price,revenue,tags,ribbon,sale_type
NEON_SEARCH_LIMIT=5

# ─────────────────────────────────────────────────────────────
# State Persistence
# Survives restarts/redeploys (chat history, roles, lead progress).
# In Docker, mount the directory as a volume to keep state.
# ─────────────────────────────────────────────────────────────
PERSISTENCE_ENABLED=true
PERSISTENCE_PATH=./.state/state.json

# ─────────────────────────────────────────────────────────────
# Access Control (allowlist + rate limit)
# ALLOWED_NUMBERS: comma-separated phone numbers (digits only, with country code).
# ─────────────────────────────────────────────────────────────
ALLOWLIST_ENABLED=false
ALLOWED_NUMBERS=
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX_MESSAGES=20
RATE_LIMIT_WINDOW_MS=60000
